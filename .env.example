# Optional for direct OpenAI API runs.
OPENAI_API_KEY=

# Optional override. Defaults to https://api.openai.com/v1.
OPENAI_BASE_URL=

# Optional for Bedrock Mantle bearer auth. If unset, the benchmark uses AWS SigV4
# credentials from the active AWS profile/session.
BEDROCK_OPENAI_API_KEY=
AWS_BEARER_TOKEN_BEDROCK=

# Optional override. Defaults to https://bedrock-mantle.<region>.api.aws/openai/v1.
BEDROCK_OPENAI_BASE_URL=
